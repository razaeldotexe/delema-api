# Delema API - Environment Configuration Example

# Server Port (Default: 8000)
PORT=8000

# Node Environment (production, development, test)
NODE_ENV=development

# Discord/Slack Webhook URL for Log Batching (Optional)
# If not provided, logs will only appear in the console.
# WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: Add other service keys here if extended
# GITHUB_TOKEN=your_github_personal_access_token

# Giphy API Key
GIPHY_API_KEY=your_giphy_api_key

# AI Provider Keys
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
